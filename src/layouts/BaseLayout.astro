---
import '../styles/global.scss';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import DotNav from '../components/common/DotNav.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Muhammed Rashid | Full Stack Developer',
  description = 'Muhammed Rashid is a Full Stack Developer specializing in React, Angular, Node.js, MongoDB, MySQL, and modern web applications.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author"  content="Muhammed Rashid" />
  <meta name="robots"  content="index, follow" />

  <link rel="canonical" href="https://devmdrd.github.io/" />

  <meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />
  <meta name="theme-color" content="#ffffff"  media="(prefers-color-scheme: light)" />

  <meta property="og:type"        content="website" />
  <meta property="og:site_name"   content="Muhammed Rashid Portfolio" />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content="Full Stack Developer specializing in React, Angular, Node.js, MongoDB, MySQL, and modern web applications." />
  <meta property="og:url"         content="https://devmdrd.github.io/" />
  <meta property="og:image"       content="https://devmdrd.github.io/assets/images/profile.webp" />

  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:site"        content="@devmdrd" />
  <meta name="twitter:creator"     content="@devmdrd" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content="Full Stack Developer specializing in React, Angular, Node.js, MongoDB, MySQL, and modern web applications." />
  <meta name="twitter:image"       content="https://devmdrd.github.io/assets/images/profile.webp" />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Muhammed Rashid",
    "url": "https://devmdrd.github.io/",
    "jobTitle": "Full Stack Developer",
    "image": "https://devmdrd.github.io/assets/images/profile.webp",
    "knowsAbout": ["React", "Angular", "Node.js", "TypeScript", "MongoDB", "MySQL"],
    "worksFor": { "@type": "Organization", "name": "Whydonate" },
    "alumniOf": { "@type": "EducationalOrganization", "name": "Santhigiri College of Computer Sciences" },
    "sameAs": [
      "https://github.com/devmdrd",
      "https://linkedin.com/in/devmdrd",
      "https://x.com/devmdrd"
    ]
  }
  </script>

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
  <link rel="preload" as="image" href="/assets/images/profile.webp" type="image/webp" />

  <link rel="preload" as="style"
        href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;700&display=optional"
        onload="this.onload=null;this.rel='stylesheet'" />
  <noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;700&display=optional" />
  </noscript>

  <link rel="preload" as="style"
        href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.7.2/css/all.min.css"
        onload="this.onload=null;this.rel='stylesheet'" />
  <noscript>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.7.2/css/all.min.css" />
  </noscript>

  <script is:inline>
    (function () {
      var s = localStorage.getItem('theme');
      document.documentElement.dataset.theme =
        s === 'dark' || s === 'light' ? s
        : window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }());
  </script>
</head>

<body>
  <a href="#about" class="skip-link">Skip to main content</a>

  <div id="loader" class="loader" role="status" aria-label="Loading portfolio">
    <p class="loader__label"><i class="fa-solid fa-terminal" aria-hidden="true"></i>loading portfolio...</p>
    <div class="loader__dots" aria-hidden="true">
      <div class="loader__dot"></div>
      <div class="loader__dot delay-150"></div>
      <div class="loader__dot delay-300"></div>
    </div>
    <p class="loader__user">@devmdrd</p>
  </div>

  <DotNav />
  <Header />

  <main class="main-content">
    <slot />
  </main>

  <Footer />

  <script defer src="https://cdn.jsdelivr.net/npm/typed.js@2.1.0/dist/typed.umd.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/countup.js@2.8.0/dist/countUp.umd.js"></script>

  <script>
    const LAST_SECTION_KEY = 'lastSection';
    const sections  = Array.from(document.querySelectorAll<HTMLElement>('section[id]'));
    const total     = sections.length;
    const container = document.querySelector<HTMLElement>('.main-content');

    function updateUI(idx: number): void {
      const id = sections[idx]?.id;
      if (!id) return;
      const bar     = document.getElementById('scroll-progress');
      const backBtn = document.getElementById('back-top-btn');
      if (bar)     bar.style.width = `${total > 1 ? (idx / (total - 1)) * 100 : 100}%`;
      if (backBtn) backBtn.classList.toggle('is-visible', idx > 0);
      document.querySelectorAll<HTMLElement>('.dot-nav__btn[data-section]').forEach(b => {
        const on = b.dataset.section === id;
        b.classList.toggle('active', on);
        if (on) b.setAttribute('aria-current', 'location');
        else    b.removeAttribute('aria-current');
      });
      try { sessionStorage.setItem(LAST_SECTION_KEY, id); } catch {}
    }

    let savedId: string | null = null;
    try { savedId = sessionStorage.getItem(LAST_SECTION_KEY); } catch {}
    let startIdx = sections.findIndex(s => s.id === savedId);
    if (startIdx === -1) startIdx = 0;
    if (startIdx > 0) sections[startIdx].scrollIntoView({ behavior: 'auto', block: 'start' });

    const scrollObserver = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const idx = sections.indexOf(entry.target as HTMLElement);
          if (idx !== -1) updateUI(idx);
        }
      });
    }, { root: container, threshold: 0.4 });

    sections.forEach(s => scrollObserver.observe(s));

    document.querySelectorAll<HTMLElement>('.dot-nav__btn[data-section]').forEach(btn => {
      btn.addEventListener('click', () => {
        document.getElementById(btn.dataset.section!)?.scrollIntoView({ behavior: 'smooth' });
      });
    });

    document.getElementById('back-top-btn')?.addEventListener('click', () => {
      sections[0]?.scrollIntoView({ behavior: 'smooth' });
    });

    document.getElementById('contact-btn')?.addEventListener('click', () => {
      document.getElementById('contact')?.scrollIntoView({ behavior: 'smooth' });
    });

    updateUI(startIdx);

    const loader = document.getElementById('loader');
    if (loader) {
      setTimeout(() => {
        loader.classList.add('is-hidden');
        document.dispatchEvent(new CustomEvent('portfolio:ready'));
      }, 600);
    } else {
      document.dispatchEvent(new CustomEvent('portfolio:ready'));
    }
  </script>
</body>
</html>
