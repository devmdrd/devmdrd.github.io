<header class="site-header">
  <div class="header-logo">
    <img src="/assets/images/profile.webp" alt="" aria-hidden="true" width="28" height="28" class="header-avatar" />
    <span class="about-qf-chip about-qf-chip--active"><span class="about-qf-dot" aria-hidden="true"></span>Open to Work</span>
  </div>
  <div class="header-end">
    <button id="theme-toggle" type="button" class="outline-btn" aria-label="Switch to light theme">
      <i class="fa-solid fa-sun"></i>
    </button>
    <span id="theme-announce" class="sr-only" aria-live="polite"></span>
    <a href="/resume.pdf" target="_blank" rel="noreferrer" class="filled-btn" aria-label="Download resume">
      <i class="fa-solid fa-download"></i><span>resume</span>
    </a>
  </div>
  <div id="scroll-progress" class="header-progress" aria-hidden="true"></div>
</header>

<script>
  const THEME_KEY = 'theme';

  function applyTheme(theme: string): void {
    document.documentElement.dataset.theme = theme;
    const btn      = document.getElementById('theme-toggle');
    const icon     = btn?.querySelector('i');
    const announce = document.getElementById('theme-announce');
    if (icon)     icon.className = theme === 'dark' ? 'fa-solid fa-sun' : 'fa-solid fa-moon';
    if (btn)      btn.setAttribute('aria-label', `Switch to ${theme === 'dark' ? 'light' : 'dark'} theme`);
    if (announce) announce.textContent = `${theme} mode enabled`;
    localStorage.setItem(THEME_KEY, theme);
  }

  const stored = localStorage.getItem(THEME_KEY);
  applyTheme(
    stored === 'dark' || stored === 'light' ? stored
    : window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
  );

  let debounceTimer: ReturnType<typeof setTimeout>;
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      applyTheme(document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark');
    }, 200);
  });
</script>
